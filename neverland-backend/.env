# ============================================
# NEVERLAND STUDIO BACKEND - UNIVERSAL CONFIG
# ============================================
# This file works for both development and production.
# Change NODE_ENV to switch between environments.

# --- ENVIRONMENT ---
# Set to 'production' when deploying, 'development' for local dev
NODE_ENV=production
PORT=5000

# --- URLs ---
# Production URLs
BACKEND_URL=https://api.neverlandstudio.my.id
FRONTEND_URL=https://neverlandstudio.my.id

# --- CORS & ALLOWED ORIGINS ---
# Production origins
ALLOWED_ORIGINS=https://neverlandstudio.my.id,https://www.neverlandstudio.my.id
ALLOWED_REDIRECT_URIS=https://neverlandstudio.my.id,https://www.neverlandstudio.my.id

# --- DATABASE ---
# Production database (update with your production DB credentials)
DB_HOST=mariadb_neverland
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=neverlandstudio
DB_DIALECT=mariadb

# --- JWT AUTHENTICATION ---
# IMPORTANT: Generate a strong random secret for production!
JWT_SECRET=adf480455555a1e2c07d7500323b80d4
JWT_EXPIRES_IN=7d

# --- SESSION SECRET ---
# IMPORTANT: Generate a strong random secret for production!
SESSION_SECRET=b36ea831b2cccc3f286ef72bb0020085cc7d508f002d1a654985c9004dd0dd8ac769ea7cdadf32ce01a1de8a444af10e52a0b4240c1838cac45daaa53f546ca0

